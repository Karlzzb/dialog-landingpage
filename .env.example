# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略。

# ============ bisheng 知识库后端 ============
BISHENG_BASE_URL=http://10.30.186.171:3001
# bisheng 登录后拿到的 access_token（JWT）。这是短期 token，过期需更新。
# 长期方案应改为可续期的登录换取 token，见 docs/PRD.md「知识库 RAG 接入」。
BISHENG_ACCESS_TOKEN=your-bisheng-access-token

# ============ 入库脚本使用的 LLM（火山引擎，独立于 agent 的两档模型）============
INGEST_LLM_API_KEY=your-volces-api-key
INGEST_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
INGEST_LLM_MODEL=deepseek-v3-2-251201

# ============ Agent 两档模型（OpenAI 兼容，共用同一 base_url + key，按角色切 model 名）============
MODEL_BASE_URL=https://your-openai-compatible-endpoint/v1
MODEL_API_KEY=your-model-api-key
# 强模型：ReAct 规划循环 + 工具编排 + 结论生成
STRONG_MODEL=kimi-2.6
# 快模型：问题改写/指代消解 + 对话流闲聊
FAST_MODEL=deepseek-v4-pro

# ============ Langfuse 可观测性（tracing）============
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_BASE_URL=http://your-langfuse-host:3000

# ============ Redis checkpointer（跨轮持久化整个 State，ADR/切片 7）============
# 连接参数取值参考 redis.conf（host/port/password/database/timeout/ssl），真实值经 .env 注入。
REDIS_HOST=172.21.123.93
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
# 通用业务 db（redis.conf 的 database=4）。
REDIS_DB=4
# checkpointer 专用 db 索引，须与 REDIS_DB 隔离，避免会话状态与业务用途串台。
REDIS_CHECKPOINTER_DB=0
REDIS_SSL=false
# 秒（对应 redis.conf 的 timeout: 10000）。
REDIS_TIMEOUT=10
# 会话记忆 TTL（分钟），可配置；占位值，待业务确认实际取值后覆盖。
SESSION_TTL_MINUTES=60
